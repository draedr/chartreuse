# HTTP port the server listens on
PORT=3000

# Directory for the SQLite db, stored originals, avatars and quarantined files
DATA_DIR=./data

# Watch folders for auto-import (cards: .png/.json, lorebooks: .json)
WATCH_CARDS_DIR=./watch/cards
WATCH_LOREBOOKS_DIR=./watch/lorebooks

# Seconds between full rescans of the watch folders
RESCAN_INTERVAL_SEC=300
